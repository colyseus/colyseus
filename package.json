{
  "name": "@colyseus/monorepo",
  "version": "0.17.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "build": "tsx build.ts",
    "build-all": "pnpm --filter @colyseus/better-call run build && pnpm run build && pnpm --filter @colyseus/sdk run build && pnpm --filter @colyseus/playground run build && pnpm --filter @colyseus/monitor run build",
    "test": "pnpm -r --filter '!./packages/better-call/**' run test",
    "example": "pnpm --filter @colyseus/example run start",
    "update-contributors": "all-contributors generate",
    "publish-from-package-stable": "pnpm run build && pnpm -r publish",
    "publish-from-package-preview": "pnpm run build && pnpm -r publish --tag preview",
    "update-submodule": "git submodule update --remote packages/better-call",
    "preinstall": "git submodule update --init --recursive",
    "postinstall": "pnpm --filter @better-auth/root run build"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/debug": "^0.0.31",
    "@types/express": "^5.0.0",
    "@types/fossil-delta": "^1.0.0",
    "@types/ioredis": "^4.27.3",
    "@types/mocha": "^10.0.1",
    "@types/node": "^22.13.14",
    "@types/sinon": "^10.0.2",
    "all-contributors-cli": "^6.20.0",
    "assert": "^2.0.0",
    "benchmark": "^2.1.1",
    "c8": "^7.7.2",
    "cors": "^2.8.5",
    "esbuild": "^0.27.2",
    "express": ">=5.0.0",
    "fast-glob": "^3.2.11",
    "httpie": "^2.0.0-next.13",
    "micromatch": "^4.0.8",
    "minimist": "^1.2.5",
    "mocha": "^10.2.0",
    "rimraf": "^2.7.1",
    "sinon": "^11.1.1",
    "ts-jest": "^28.0.3",
    "tsx": "^4.1.2",
    "typescript": "^5.9.3",
    "@colyseus/schema": "^4.0.13"
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src",
      "test"
    ],
    "reporter": [
      "html",
      "lcov"
    ],
    "all": true
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.15.0"
  }
}
